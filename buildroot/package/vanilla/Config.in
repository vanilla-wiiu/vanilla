config BR2_PACKAGE_VANILLA
	bool "vanilla"
	help
		Install Vanilla, the Wii U gamepad reimplementation

		https://github.com/vanilla-wiiu/vanilla

if BR2_PACKAGE_VANILLA

config BR2_PACKAGE_VANILLA_BUILD_GUI
    bool "Enable GUI"
    default y
    select BR2_PACKAGE_SDL2
    select BR2_PACKAGE_SDL2_TTF
    select BR2_PACKAGE_SDL2_IMAGE
    help
        Build the frontend. Enable if you're building a fully embedded
        device for Vanilla, disable if the device is only handling
        the connection to the Wii U.

config BR2_PACKAGE_VANILLA_BUILD_PIPE
    bool "Enable pipe"
    default y
    help
        Build the pipe. Enable if this device can connect to the Wii U
        on its own. Disable if it will need to go through a separate
        device (called a "pipe") to make the connection.

config BR2_PACKAGE_VANILLA_USE_VAAPI
    bool "Enable VAAPI"

config BR2_PACKAGE_VANILLA_USE_DRM
    bool "Enable DRM"
    default y

config BR2_PACKAGE_VANILLA_USE_NX_IMU
    bool "Use Nintendo Switch motion sensors"

config BR2_PACKAGE_VANILLA_USE_LOCAL
    bool "Local build"
    help
        Use a local build directory rather than pulling from GitHub.
        Useful for Docker builds or development.

config BR2_PACKAGE_VANILLA_LOCAL_PATH
    depends on BR2_PACKAGE_VANILLA_USE_LOCAL
    string "Local repository path"
    help
        Local directory to build Vanilla.

endif
